# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/.specstory

# playwright
/test-results/
/playwright-report/
/playwright/.cache/
/tests/screenshots/

# local development data (auto-synced JSON copies for dev server)
/public/data/akyo-data-*.json

# next.js
/.next/
/out/
/.open-next/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env.local

# Test screenshots
tests/screenshots/*.png
.wrangler/

# firecrawl scrape cache
.firecrawl/

# claude local settings
.claude/settings.local.json
