{
  "name": "akyodex-nextjs",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "next:build": "next build",
    "next:build:opennext": "next build && node scripts/fix-opennext-instrumentation.js",
    "build": "opennextjs-cloudflare build && node scripts/prepare-cloudflare-pages.js",
    "start": "next start",
    "lint": "eslint",
    "verify:dify-csp-hash": "node scripts/verify-dify-csp-hash.js",
    "knip": "knip",
    "social:generate": "node scripts/generate-social-images.js",
    "social:compress": "node scripts/compress-social-images.js",
    "test": "playwright test",
    "test:playwright": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:csv": "node scripts/test-csv-quality.js",
    "data:convert": "npx tsx scripts/csv-to-json.ts",
    "generate-ko-data": "node scripts/generate-ko-data.js",
    "push:check-pr": "node scripts/push-and-check-pr-conflicts.js",
    "hooks:install": "git config --local core.hooksPath .githooks"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.18.0",
    "@sentry/nextjs": "^10.46.0",
    "csv-parse": "^6.1.0",
    "csv-stringify": "^6.6.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sanitize-html": "^2.17.0"
  },
  "overrides": {
    "minimatch": "10.2.4",
    "@aws-sdk/xml-builder": {
      "fast-xml-parser": "5.5.9"
    },
    "eslint": {
      "ajv": "6.14.0"
    },
    "@eslint/eslintrc": {
      "ajv": "6.14.0"
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "knip": "^5.66.4",
    "postcss": "^8.4.49",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "typescript": "5.9.3",
    "wrangler": "^4.75.0"
  }
}
